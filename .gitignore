# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/android/.gradle
/android/app/build
/android/build
/android/local.properties
*.apk
*.aab

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# synced reformer video files (manifest.json is kept)
/public/videos/reformer/*.mp4
/public/videos/reformer/*.webm
/public/videos/reformer/*.mkv
/public/videos/reformer/*.mov
/public/videos/reformer/*.info.json
